# --- CONFIGURAÇÕES DO BANCO DE DATOS (POSTGRES) ---
POSTGRES_USER=gfp_user
POSTGRES_PASSWORD=gfp_password
POSTGRES_DB=gfp_db
POSTGRES_PORT=5432

# URL de conexão para o Prisma (usada em desenvolvimento local)
# Conecta via localhost pois o container DB expõe a porta 5432
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# URL de conexão interna para o Docker Compose (usada pelo container 'app')
# O host aponta para o nome do serviço 'db' definido no docker-compose.yml
DOCKER_DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# --- CONFIGURAÇÕES DA APLICAÇÃO (DOCKER/NEXT) ---
APP_PORT=3000
NEXT_PUBLIC_SITE_URL=http://app.127.0.0.1.nip.io:3000
CONTAINER_NAME_APP=gfp_app
CONTAINER_NAME_DB=gfp_db
